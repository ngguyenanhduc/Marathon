<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <servlet>
        <servlet-name>ApproveOrganizerController</servlet-name>
        <servlet-class>controller.ApproveOrganizerController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ApproveRaceController</servlet-name>
        <servlet-class>controller.ApproveRaceController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ManageUserController</servlet-name>
        <servlet-class>controller.ManageUserController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ApproveOrganizerController</servlet-name>
        <url-pattern>/ApproveOrganizerController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ApproveRaceController</servlet-name>
        <url-pattern>/ApproveRaceController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ManageUserController</servlet-name>
        <url-pattern>/ManageUserController</url-pattern>
    </servlet-mapping>
</web-app>
