<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0"
         xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">

    <filter>
        <filter-name>RunnerAuthorizationFilter</filter-name>
        <filter-class>filter.RunnerAuthorizationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>RunnerAuthorizationFilter</filter-name>
        <url-pattern>/runner/*</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>TestDB</servlet-name>
        <servlet-class>controller.TestDB</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>controller.auth.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>controller.auth.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>controller.auth.RegisterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RaceListServlet</servlet-name>
        <servlet-class>controller.publicpage.RaceListServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RaceDetailServlet</servlet-name>
        <servlet-class>controller.publicpage.RaceDetailServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RunnerProfileServlet</servlet-name>
        <servlet-class>controller.runner.RunnerProfileServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RunnerRegistrationListServlet</servlet-name>
        <servlet-class>controller.runner.RunnerRegistrationListServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RunnerRegisterRaceServlet</servlet-name>
        <servlet-class>controller.runner.RunnerRegisterRaceServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RunnerOrganizerRequestServlet</servlet-name>
        <servlet-class>controller.runner.RunnerOrganizerRequestServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>TestDB</servlet-name>
        <url-pattern>/testdb</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RaceListServlet</servlet-name>
        <url-pattern>/races</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RaceDetailServlet</servlet-name>
        <url-pattern>/race-detail</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RunnerProfileServlet</servlet-name>
        <url-pattern>/runner/profile</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RunnerRegistrationListServlet</servlet-name>
        <url-pattern>/runner/registrations</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RunnerRegisterRaceServlet</servlet-name>
        <url-pattern>/runner/register-race</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RunnerOrganizerRequestServlet</servlet-name>
        <url-pattern>/runner/organizer-request</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>races</welcome-file>
    </welcome-file-list>
</web-app>
